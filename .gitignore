# Stamp files used by the agent to track when it last prompted you.
# These are local state, not content — safe to ignore.
.agents-local-last-prompt
.agents-last-lint
.scaffold-upstream

# OS / editor noise
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# Per-user / per-machine preferences. Different users and checkouts maintain
# their own; shared family-level settings live in AGENTS.family.md. See PRIVACY.md.
AGENTS.local.md

# Optional overlay layer, injected by a host application at setup (if any).
# Never committed — each instance's overlay, if present, is environment-specific.
# See AGENTS.overlay.md.example for the expected shape.
AGENTS.overlay.md

# Instance-only docs (upgrade notes, per-instance plans, scratch work) that
# should never be published. Safe place for anything private.
.local/

# Overlay extension surface — host-app skills, hooks, and per-user / overlay
# settings registrations. These sit alongside the upstream-tracked generic
# `.agents/` surface and Claude Code compatibility files but are never
# committed; each instance's additions stay local.
# See AGENTS.overlay.md.example "Overlay-injected skills, hooks, and settings".
.agents/skills.overlay/
.agents/hooks.overlay/
.agents/settings.local.json
.claude/skills.overlay/
.claude/hooks.overlay/
.claude/settings.local.json
