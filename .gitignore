# Stamp files used by the agent to track when it last prompted you.
# These are local state, not content — safe to ignore.
.agents-local-last-prompt
.agents-last-lint

# OS / editor noise
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# Per-user / per-machine preferences. Different users and checkouts maintain
# their own; shared family-level settings live in AGENTS.md. See PRIVACY.md.
AGENTS.local.md

# Instance-only docs (upgrade notes, per-instance plans, scratch work) that
# should never be published. Safe place for anything private.
.local/
